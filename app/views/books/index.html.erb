<div class="container">
  <div class="row">
    <div class="col-md-3">
      <%= render 'book', user: @user, book: @book %>
    </div>

    <div class="col-md-8 offset-md-1">
      <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
        <h2 class="h5 mb-0 font-weight-bold">Home</h2>
      </div>
      
      <div class="p-3 border-bottom bg-light">
        <span class="text-muted small">Sort by:</span>
        <%= link_to '最新順', books_path(latest: "true"), class: "badge badge-pill badge-light border mx-1" %>
        <%= link_to '評価順', books_path(star_count: "true"), class: "badge badge-pill badge-light border mx-1" %>
        <%= link_to 'トレンド', books_path, class: "badge badge-pill badge-light border mx-1" %>
      </div>

      <div id="book-list">
        <% @books.each do |book| %>
          <div class="book-card border-bottom p-3 d-flex" data-weekly-likes="<%= book.favorites.where(created_at: @from..@to).count %>">
            <div class="mr-3">
              <%= link_to user_path(book.user.id) do %>
                <%= image_tag book.user.get_profile_image(48, 48), size: "48x48", class: "rounded-circle" %>
              <% end %>
            </div>
            <div class="flex-grow-1">
              <div class="d-flex align-items-center mb-1">
                <%= link_to book.user.name, user_path(book.user.id), class: "font-weight-bold text-dark mr-2" %>
                <span class="text-muted small">@<%= book.user.name %> · <%= time_ago_in_words(book.created_at) %></span>
              </div>
              
              <div class="mb-2">
                <p class="mb-1"><%= link_to book.title, book_path(book.id), class: "text-dark font-weight-bold" %></p>
                <p class="text-secondary mb-2"><%= book.body %></p>
                
                <% if book.category.present? %>
                  <span class="text-primary small">#<%= link_to book.category, search_path(word: book.category, range: "Book", search_method: "perfect") %></span>
                <% end %>
              </div>

              <div class="mb-2">
                <%= render 'star_display', star_count: book.star, book_id: book.id %>
              </div>

              <div class="favorite-btn-wrapper d-flex justify-content-between text-muted" style="max-width: 300px;">
                <div class="d-flex align-items-center">
                  <i class="far fa-comment mr-2"></i> <%= book.book_comments.count %>
                </div>
                
                <div class="d-flex align-items-center" id="favorite-button-<%= book.id %>">
                  <%= render 'favorites/favorite_button', book: book %>
                </div>

                <div class="d-flex align-items-center small">
                  <i class="far fa-eye mr-2"></i> <%= book.view_counts %>
                </div>
                
                <div class="small">
                  <i class="fas fa-chart-line mr-1 text-info"></i> <span id="weekly-likes-<%= book.id %>"><%= book.favorites.where(created_at: @from..@to).count %></span>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
