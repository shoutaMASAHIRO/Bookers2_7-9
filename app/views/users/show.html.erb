<div class="container">
  <div class="row">
    <div class="col-md-3">
      <%= render 'books/book', user: @user, book: @book %>
    </div>
    <div class="col-md-8 offset-md-1 border-left border-right px-0">
      <div class="p-3 border-bottom d-flex align-items-center">
        <%= link_to :back, class: "text-dark mr-4" do %>
          <i class="fas fa-arrow-left"></i>
        <% end %>
        <div>
          <h2 class="h5 mb-0 font-weight-bold"><%= @user.name %></h2>
          <small class="text-muted"><%= @user.books.count %> Posts</small>
        </div>
      </div>

      <div class="posts-timeline">
        <% @books.each do |book| %>
          <div class="p-3 border-bottom d-flex book-card">
            <div class="mr-3">
              <%= image_tag book.user.get_profile_image(48, 48), size: "48x48", class: "rounded-circle border" %>
            </div>
            <div class="flex-grow-1">
              <div class="d-flex align-items-center mb-1">
                <span class="font-weight-bold text-dark mr-2"><%= book.user.name %></span>
                <span class="text-muted small">@<%= book.user.name %> · <%= time_ago_in_words(book.created_at) %></span>
              </div>
              <h5 class="h6 font-weight-bold mb-1"><%= link_to book.title, book_path(book.id), class: "text-dark" %></h5>
              <p class="text-secondary mb-2"><%= book.body %></p>
              <%= render 'books/star_display', star_count: book.star, book_id: book.id %>
              
              <div class="d-flex justify-content-between text-muted mt-2" style="max-width: 200px;">
                <div class="small"><i class="far fa-comment"></i> <%= book.book_comments.count %></div>
                <div id="favorite-button-<%= book.id %>">
                  <%= render 'favorites/favorite_button', book: book %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="p-4 bg-light border-top">
        <h3 class="h6 font-weight-bold text-uppercase text-muted mb-4">Analytics</h3>
        
        <div class="card mb-4 border-0 shadow-none">
          <div class="card-body p-0">
            <table class="table table-sm border-0 mb-0">
              <thead class="bg-white border-bottom">
                <tr class="text-muted small">
                  <th class="border-0">Today</th>
                  <th class="border-0">Yesterday</th>
                  <th class="border-0">Ratio</th>
                </tr>
              </thead>
              <tbody>
                <tr class="h5 font-weight-bold">
                  <td class="border-0"><%= @today_book.count %></td>
                  <td class="border-0"><%= @yesterday_book.count %></td>
                  <td class="border-0 text-primary">
                    <% if @yesterday_book.count == 0 %>
                      -
                    <% else %>
                      <%= (@today_book.count / @yesterday_book.count.to_f * 100).round %>%
                    <% end %>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="card mb-4 border-0 shadow-none">
          <div class="card-body p-0">
            <table class="table table-sm border-0 mb-0">
              <thead class="bg-white border-bottom">
                <tr class="text-muted small">
                  <th class="border-0">This Week</th>
                  <th class="border-0">Last Week</th>
                  <th class="border-0">Ratio</th>
                </tr>
              </thead>
              <tbody>
                <tr class="h5 font-weight-bold">
                  <td class="border-0"><%= @this_week_book.count %></td>
                  <td class="border-0"><%= @last_week_book.count %></td>
                  <td class="border-0 text-primary">
                    <% if @last_week_book.count == 0 %>
                      -
                    <% else %>
                      <%= (@this_week_book.count / @last_week_book.count.to_f * 100).round %>%
                    <% end %>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="bg-white p-3 border rounded mb-4">
          <h4 class="small font-weight-bold text-muted mb-3">7-Day Activity</h4>
          <canvas id="myLineChart" height="150"></canvas>
        </div>

        <div class="bg-white p-3 border rounded">
          <h4 class="small font-weight-bold text-muted mb-3">Lookup by Date</h4>
          <%= form_with url: search_posts_user_path(@user), method: :get, local: false, class: "form-inline" do |f| %>
            <%= f.date_field :created_at, class: "form-control form-control-sm mr-2" %>
            <%= f.submit "Search", class: "btn btn-primary btn-sm" %>
          <% end %>
          <div id="search-result" class="mt-3"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  $(document).on('turbolinks:load', function() {
    var ctx = document.getElementById("myLineChart");
    if (ctx) {
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: ['6d ago', '5d', '4d', '3d', '2d', '1d', 'Today'],
          datasets: [{
            label: 'Posts',
            data: <%= @books_count_by_day.to_json.html_safe %>,
            borderColor: "#1d9bf0",
            backgroundColor: "rgba(29, 155, 240, 0.1)",
            fill: true,
            tension: 0.4
          }]
        },
        options: {
          plugins: { legend: { display: false } },
          scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
      });
    }
  });
</script>
